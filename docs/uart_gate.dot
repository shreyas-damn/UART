digraph "uart" {
label="uart";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="busy", color="black", fontcolor="black"];
n2 [ shape=octagon, label="clk", color="black", fontcolor="black"];
n3 [ shape=octagon, label="rst", color="black", fontcolor="black"];
n4 [ shape=diamond, label="rx_baud_tick", color="black", fontcolor="black"];
n5 [ shape=octagon, label="rx_data", color="black", fontcolor="black"];
n6 [ shape=octagon, label="rx_done", color="black", fontcolor="black"];
n7 [ shape=diamond, label="tx", color="black", fontcolor="black"];
n8 [ shape=diamond, label="tx_baud_tick", color="black", fontcolor="black"];
n9 [ shape=octagon, label="tx_data", color="black", fontcolor="black"];
n10 [ shape=octagon, label="tx_done", color="black", fontcolor="black"];
n11 [ shape=octagon, label="tx_start", color="black", fontcolor="black"];
c13 [ shape=record, label="{{<p2> clk|<p3> rst}|UUT1\n$paramod$9da5c3afe2a58f83191830787238f4d6d8b98d33&#9586;baud_gen|{<p12> baud_tick}}",  ];
c14 [ shape=record, label="{{<p2> clk|<p3> rst}|UUT2\n$paramod$39a12da85e615a81e533773b9ada3aec9452923f&#9586;baud_gen|{<p12> baud_tick}}",  ];
c15 [ shape=record, label="{{<p12> baud_tick|<p2> clk|<p3> rst|<p9> tx_data|<p11> tx_start}|UUT3\ntx|{<p1> busy|<p7> tx|<p10> tx_done}}",  ];
c17 [ shape=record, label="{{<p12> baud_tick|<p2> clk|<p3> rst|<p16> rx}|UUT4\nrx|{<p5> rx_data|<p6> rx_done}}",  ];
c15:p1:e -> n1:w [color="black", fontcolor="black", label=""];
c15:p10:e -> n10:w [color="black", fontcolor="black", label=""];
n11:e -> c15:p11:w [color="black", fontcolor="black", label=""];
n2:e -> c13:p2:w [color="black", fontcolor="black", label=""];
n2:e -> c14:p2:w [color="black", fontcolor="black", label=""];
n2:e -> c15:p2:w [color="black", fontcolor="black", label=""];
n2:e -> c17:p2:w [color="black", fontcolor="black", label=""];
n3:e -> c13:p3:w [color="black", fontcolor="black", label=""];
n3:e -> c14:p3:w [color="black", fontcolor="black", label=""];
n3:e -> c15:p3:w [color="black", fontcolor="black", label=""];
n3:e -> c17:p3:w [color="black", fontcolor="black", label=""];
c14:p12:e -> n4:w [color="black", fontcolor="black", label=""];
n4:e -> c17:p12:w [color="black", fontcolor="black", label=""];
c17:p5:e -> n5:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c17:p6:e -> n6:w [color="black", fontcolor="black", label=""];
c15:p7:e -> n7:w [color="black", fontcolor="black", label=""];
n7:e -> c17:p16:w [color="black", fontcolor="black", label=""];
c13:p12:e -> n8:w [color="black", fontcolor="black", label=""];
n8:e -> c15:p12:w [color="black", fontcolor="black", label=""];
n9:e -> c15:p9:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
}
